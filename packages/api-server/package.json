    "@fastify/swagger": "^9.7.0",
    "@google-cloud/secret-manager": "^6.1.3",
    "@shipit-ai/connector-github": "workspace:*",
    "@shipit-ai/connector-sdk": "workspace:*",
    "@shipit-ai/event-bus": "workspace:*",
    "@shipit-ai/mcp-server": "workspace:*",
    "@shipit-ai/shared": "workspace:*",
    "bullmq": "^5.78.1",
    "fastify": "^5.8.5",
    "ioredis": "^5.11.1",
    "neo4j-driver": "^6.1.0",
    "openid-client": "^6.8.4",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/ioredis-mock": "^8.2.7",
    "ioredis-mock": "^8.13.1",
    "typescript": "^6.0.3",
