{
  "name": "@shipit-ai/api-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.15.0",
    "@shipit-ai/connector-github": "workspace:*",
    "@shipit-ai/connector-sdk": "workspace:*",
    "@shipit-ai/event-bus": "workspace:*",
    "@shipit-ai/mcp-server": "workspace:*",
    "@shipit-ai/shared": "workspace:*",
    "bullmq": "^5.34.0",
    "fastify": "^4.28.0",
    "ioredis": "^5.4.0",
    "neo4j-driver": "^5.27.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
