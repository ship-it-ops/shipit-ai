# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=shipit-dev

# Redis
REDIS_URL=redis://localhost:6379

# API Server
API_SERVER_PORT=3001
API_SERVER_URL=http://localhost:3001

# Web UI
NEXT_PUBLIC_API_URL=http://localhost:3001

# Web UI — mock current user (no auth layer yet). Populates the profile page
# and user menu. Replace with real auth before shipping. NEXT_PUBLIC_* is
# required so the values reach client components (inlined at build time).
NEXT_PUBLIC_DEV_USER_FIRST_NAME=Dev
NEXT_PUBLIC_DEV_USER_LAST_NAME=User
NEXT_PUBLIC_DEV_USER_EMAIL=dev@shipit.local
NEXT_PUBLIC_DEV_USER_ROLE=Platform Admin
NEXT_PUBLIC_DEV_USER_TEAM=platform-team
NEXT_PUBLIC_DEV_USER_JOINED_AT=2026-01-01
# Comma-separated. Mirrors what RBAC will eventually grant.
NEXT_PUBLIC_DEV_USER_CAPABILITIES=admin,graph:write,connectors:manage,schema:edit,mcp:invoke

# GitHub Connector
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_INSTALLATION_ID=
GITHUB_ORG=

# ─── Incident Mode integration adapters ──────────────────────────────────────
# Each adapter activates only when its env var is set; unset ones simply hide
# their button from the dashboard. Customers wire whichever incident toolchain
# they actually use — see packages/web-ui/src/lib/integrations/.
#
# NEXT_PUBLIC_* is required so the values reach client components (inlined at
# build time).

# PagerDuty — your account subdomain (e.g. "acme-pay" for acme-pay.pagerduty.com)
NEXT_PUBLIC_PAGERDUTY_SUBDOMAIN=

# Datadog — your site (datadoghq.com, datadoghq.eu, us3.datadoghq.com, …)
NEXT_PUBLIC_DATADOG_SITE=

# GitHub — org slug used to construct repo deeplinks when the catalog Repository
# node lacks an explicit `url` property
NEXT_PUBLIC_GITHUB_ORG=

# Kubernetes — URL template with {cluster}, {namespace}, {name} placeholders.
# Examples:
#   Argo CD: https://argo.acme.com/applications/{namespace}/{name}
#   Lens:    lens://catalog/general/{cluster}/{namespace}/{name}
#   Generic: https://k8s-console.acme.com/{cluster}/{namespace}/{name}
NEXT_PUBLIC_K8S_CONSOLE_URL=

# Slack — workspace subdomain (e.g. "acme" for https://acme.slack.com)
NEXT_PUBLIC_SLACK_WORKSPACE=
# Optional: prefix used to derive a team's standing channel name from its
# catalog slug (default: "team-")
NEXT_PUBLIC_SLACK_CHANNEL_PREFIX=
